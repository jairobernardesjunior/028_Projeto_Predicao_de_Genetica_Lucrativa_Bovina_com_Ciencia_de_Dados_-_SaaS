<?xml version="1.0"?>
<brblup>
  <files>
    <file filename="brblup_data_raw.csv" type="obs"/>
    <file filename="brblup_pedigree_raw.csv" type="ped"/>
    <file filename="brblup_genotypes_raw.txt" type="gen"/>
    <file filename="brblup_map_raw.csv" type="map"/>
  </files>
  <model type="animal">
    <!-- Exemplo de mapeamento para o arquivo RAW com cabeçalhos -->
    <!-- Nota: O software brblup requer IDs numéricos e categorias inteiras para processar. -->
    
    <!-- Trait: PN_kg (Coluna index 2) -->
    <trait type="real" column="2" levels="1"/>
    
    <!-- Efeito Fixo: Fazenda (Coluna index 15) -->
    <!-- Níveis devem ser definidos após a codificação -->
    <effect type="alpha" columns="15" levels="0"/> 
    
    <!-- Efeito Aleatório: Animal (Coluna index 0) -->
    <effect type="alpha" columns="0" levels="0"/>
    
    <equation trait="0" effects="0,1"/>
    
    <covariances>1.0</covariances>
    <group effects="1" type="animal" inbreeding="no">
      <covariances>1.0</covariances>
    </group>
  </model>
</brblup>
